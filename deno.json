{
  "name": "@linuxwolf/andthen",
  "short_name": "andthen",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "exclude": [
    ".cache/**"
  ],
  "fmt": {
    "exclude": ["docs/**"]
  },
  "lint": {
    "exclude": ["docs/**"]
  },
  "test": {
    "include": ["test/**/*.test.ts"]
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.5",
    "@std/testing": "jsr:@std/testing@^1.0.2",
    "expecto/": "https://deno.land/x/expecto@v0.1.4/mod/",
    "zod": "npm:zod@^3.23.8"
  },
  "tasks": {
    "cover": "deno test --clean --junit-path report.xml --coverage coverage test && deno coverage --exclude=test/setup.ts --html coverage"
  }
}
